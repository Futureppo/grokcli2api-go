# grokcli2api-go configuration template
# Copy to `.env` and fill in the values.

# ---- Server ----
GROK2API_HOST=0.0.0.0
GROK2API_PORT=8088
GROK2API_LOG_LEVEL=INFO

# ---- Upstream Grok API ----
# The address Grok CLI itself points to. Override only if you know what you are doing.
GROK_CHAT_PROXY_BASE_URL=https://cli-chat-proxy.grok.com
GROK_CHAT_PROXY_VERSION=v1

# ---- Auth: pick one ----
# 1) SessionToken (easiest): paste a SessionToken directly.
# GROK_SESSION_TOKEN=...

# 2) OAuth from a previously authorized Grok CLI install:
#    grok.exe will store ~/.grok/auth.json. Point this to the file.
GROK_AUTH_FILE=

# 3) Headless OAuth via device flow (still implementing).
# GROK_OAUTH_CLIENT_ID=
# GROK_OAUTH_CLIENT_SECRET=

# ---- Client identity ----
# These mirror the `x-grok-*` headers that the official CLI sends.
# Override only when you want to test different surfaces.
GROK_CLIENT_NAME=grok-shell
# Update this value if upstream returns HTTP 426 with a newer minimum version.
GROK_CLIENT_VERSION=0.2.93
GROK_CLIENT_SURFACE=tui
GROK_CLIENT_IDENTIFIER=grok-shell
GROK_TOKEN_AUTH=xai-grok-cli

# ---- Network ----
# Disable TLS certificate verification only in a controlled debugging environment.
# GROK_TLS_INSECURE_SKIP_VERIFY=false

# ---- Outbound proxy (applied to all calls to cli-chat-proxy.grok.com) ----
# Supports http://, https:// (CONNECT), socks5://, and socks5h://.
# Examples:
#   GROK_PROXY_URL=http://127.0.0.1:8080            # mitmproxy local
#   GROK_PROXY_URL=socks5://user:pass@127.0.0.1:1080
#   GROK_PROXY_URL=http://corp-proxy.internal:3128
# When unset, Go honours standard HTTP_PROXY / HTTPS_PROXY / ALL_PROXY env vars.
# GROK_PROXY_URL=

# Comma-separated hostnames / patterns to bypass the proxy even when GROK_PROXY_URL is set.
# Patterns follow the standard NO_PROXY grammar (e.g. "localhost,*.internal,10.0.0.0/8").
# GROK_NO_PROXY=localhost,127.0.0.1

# ---- Server-side API key gate ----
# Optional. Empty (default) = no gate. When set, protected API and upstream
# passthrough endpoints must include `Authorization: Bearer <key>`, `x-api-key:
# <key>`, or `api-key: <key>`. OpenAI SDK clients forward their `api_key`
# argument as the Bearer token automatically.
# Multiple keys allowed; mint one per client without restarting.
# GROK_API_KEYS=key1,key2,key3
# Legacy single-key alias still works:
# GROK_API_KEY=
